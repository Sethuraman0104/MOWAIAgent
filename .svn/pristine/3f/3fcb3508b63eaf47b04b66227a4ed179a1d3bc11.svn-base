<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOW AI Control Center - Dashboard</title>

    <link rel="icon" type="image/png" href="assets/appicon.png">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="css/admin.css">
</head>

<body>
    <!-- MOBILE HEADER -->
    <div class="mobile-header">

        <button class="mobile-menu-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="mobile-brand">
            <img src="assets/mowlogo.png" alt="">
            <div>
                <h3>MOW AI</h3>
                <span>Knowledge Administration Platform</span>
            </div>
        </div>

    </div>

    <div class="mobile-overlay" onclick="closeSidebar()"></div>

    <div class="page">
        <aside class="sidebar" id="sidebar">

            <div>

                <div class="brand-card">

                    <div class="logo-shell">
                        <img src="assets/mowlogo.png" alt="">
                    </div>

                    <h2>MOW AI</h2>

                    <p>
                        Knowledge Administration Platform
                    </p>

                </div>

                <nav>

                    <a href="MOWAIHome.html" class="nav-card active">
                        <i class="fas fa-house"></i>
                        <div>
                            <strong>Dashboard</strong>
                            <small>Overview</small>
                        </div>
                    </a>

                    <a href="documents.html" class="nav-card">
                        <i class="fas fa-file-lines"></i>
                        <div>
                            <strong>Documents</strong>
                            <small>Training Files</small>
                        </div>
                    </a>

                    <a href="urls.html" class="nav-card">
                        <i class="fas fa-link"></i>
                        <div>
                            <strong>URLs</strong>
                            <small>Knowledge Sources</small>
                        </div>
                    </a>

                    <a href="predefined.html" class="nav-card">
                        <i class="fas fa-circle-question"></i>
                        <div>
                            <strong>Questions</strong>
                            <small>AI Answers</small>
                        </div>
                    </a>

                </nav>

            </div>

            <!-- FOOTER -->

            <div class="sidebar-footer">

                <div class="footer-divider"></div>

                <div class="app-info">

                    <div class="app-badge">
                        <i class="fas fa-robot"></i>
                        MOW AI
                    </div>

                    <div class="app-meta">
                        Version 1.0.0
                    </div>

                    <div class="app-meta">
                        Developed by MOW ITD Team
                    </div>

                    <div class="app-meta">
                        © 2026 Ministry of Works
                    </div>

                </div>

            </div>

        </aside>

        <!-- MAIN CONTENT -->
        <main class="content">

            <header class="topbar">

                <div>
                    <h1><i class="fas fa-robot"></i> MOW AI Control Center</h1>
                    <p>
                        Knowledge Management & Chatbot Administration
                    </p>
                </div>

                <div class="topbar-right">
                    <div class="user-profile">

                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                            <span class="user-online"></span>
                        </div>

                        <div class="user-details">
                            <strong id="loggedInFullName">Loading...</strong> 
                            <small id="loggedInUser">Authenticated User</small>
                        </div>

                    </div>

                </div>

            </header>

            <!-- HERO -->
            <section class="hero">

                <div class="hero-left">

                    <div class="tag">
                        <i class="fas fa-sparkles"></i>
                        Artificial Intelligence Platform
                    </div>

                    <h2>
                        Manage Knowledge Sources
                        For MOW AI Chatbot
                    </h2>

                    <p>
                        Configure chatbot behaviour, train AI using
                        documents and URLs, and manage predefined
                        responses from one centralized dashboard.
                    </p>

                </div>

                <div class="hero-right">

                    <div class="orb"></div>

                </div>

            </section>

            <!-- QUICK ACCESS -->
            <section class="cards">

                <a href="documents.html" class="dashboard-card">

                    <i class="fas fa-file-alt"></i>

                    <h3>Documents</h3>

                    <p>
                        Manage uploaded AI knowledge documents.
                    </p>

                </a>

                <a href="urls.html" class="dashboard-card">

                    <i class="fas fa-link"></i>

                    <h3>URLs</h3>

                    <p>
                        Configure approved websites for AI training.
                    </p>

                </a>

                <a href="predefined.html" class="dashboard-card">

                    <i class="fas fa-question-circle"></i>

                    <h3>Questions</h3>

                    <p>
                        Manage predefined AI responses.
                    </p>

                </a>

                <!-- 🔐 NEW: SECURITY ADMIN MODULE -->
                <a href="admin/security-dashboard.html" class="dashboard-card">

                    <i class="fas fa-shield-alt"></i>

                    <h3>Security & Admin</h3>

                    <p>
                        Manage users, audit logs, and AI query monitoring.
                    </p>

                </a>

            </section>

        </main>

    </div>

    <!-- CHAT BUTTON -->
    <button id="openChatBtn">
        <i class="fas fa-robot"></i>
    </button>

    <div id="chatWidget" class="hidden">

        <div id="chatHeader">

            <div class="chatBrand">

                <div class="chatLogo">
                    <i class="fas fa-robot"></i>
                </div>

                <div>

                    <strong>MOW AI Assistant</strong>

                    <small>Knowledge Engine</small>

                </div>

            </div>

            <button onclick="toggleChat()">
                <i class="fas fa-times"></i>
            </button>

        </div>

        <div id="chatBody"></div>

        <div id="chatInputContainer">

            <input type="text" id="chatInput" placeholder="Ask AI anything...">

            <button onclick="sendChat()">
                <i class="fas fa-paper-plane"></i>
            </button>

        </div>

    </div>

    <!-- ================= SCRIPTS ================= -->
    <script src="js/api.js"></script>

    <script>
        let loggedInUserName = "";
        let loggedInFullName = "";
        window.onload = async function () {

            try {
                const authorized = await validateLogin();

                if (authorized) {

                    console.log("Successfully");
                }
            }
            catch (ex) {

                console.error("Startup Error:", ex);

                showAlert(
                    'error',
                    'Error',
                    ex.message || 'Failed to load page'
                );
            }
        };

        async function validateLogin() {

            try {

                console.log("Before Validate API");

                const response =
                    await apiGet('/api/auth/validate');

                console.log("After Validate API", response);

                loggedInUserName = response.userName || "";
                loggedInFullName = response.fullName || "";

                setAuditUser(loggedInUserName, loggedInFullName);

                console.log("========== MOW AI LOGIN ==========");
                console.log("User Name :", loggedInUserName);
                console.log("Full Name :", loggedInFullName);
                console.log("Authorized:", response.isAuthorized);
                console.log("Login Time:", new Date().toLocaleString());
                console.log("==================================");

                if (!response.isAuthorized) {

                    document.body.innerHTML = `
            <div class="auth-page">
                <div class="auth-card">

                    <div class="auth-logo">
                        <img src="../assets/mowlogo.png">
                    </div>

                    <div class="auth-icon">
                        <i class="fas fa-user-lock"></i>
                    </div>

                    <h1>Access Denied</h1>

                    <h2>You Are Not Authorized</h2>

                    <p>
                        Your Active Directory account was successfully identified,
                        however you have not been granted access to the
                        MOW AI Administration Portal.
                    </p>

                    <div class="auth-info">
                        Please contact the MOW ITD Team if you require
                        access to this application.
                    </div>

                    <div class="auth-footer">
                        Ministry of Works • MOW AI Administration Portal
                    </div>

                </div>
            </div>`;

                    return false;
                }

                const userElement =
                    document.getElementById("loggedInUser");

                const fullNameElement =
                    document.getElementById("loggedInFullName");

                if (userElement)
                    userElement.textContent =
                        loggedInUserName || "Unknown User";

                if (fullNameElement)
                    fullNameElement.textContent =
                        loggedInFullName || "Authenticated User";

                return true;
            }
            catch (e) {

                console.error(e);

                document.body.innerHTML = `
        <div class="auth-page">

            <div class="auth-card">

                <div class="auth-logo">
                    <img src="../assets/mowlogo.png">
                </div>

                <div class="auth-icon">
                    <i class="fas fa-shield-halved"></i>
                </div>

                <h1>MOW AI Control Center</h1>

                <h2>Authentication Failed</h2>

                <p>
                    We were unable to verify your identity through the Ministry of Works
                    authentication service.
                </p>

                <div class="auth-info">
                    <strong>Possible Reasons:</strong><br><br>

                    • Windows Authentication is not enabled.<br>
                    • Your Active Directory account could not be identified.<br>
                    • The MOW AI API service is unavailable.<br>
                    • Network or security restrictions prevented authentication.
                </div>

                <button class="auth-btn" onclick="location.reload()">
                    <i class="fas fa-rotate-right"></i>
                    Try Again
                </button>

                <div class="auth-footer">
                    Ministry of Works • Artificial Intelligence Platform<br>
                    Version 1.0.0
                </div>

            </div>

        </div>`;

                return false;
            }
        }

        function toggleSidebar() {

            document
                .querySelector('.sidebar')
                .classList.toggle('show');

            document
                .querySelector('.mobile-overlay')
                .classList.toggle('show');

            document.body.classList.toggle('menu-open');
        }

        function closeSidebar() {

            document
                .querySelector('.sidebar')
                .classList.remove('show');

            document
                .querySelector('.mobile-overlay')
                .classList.remove('show');

            document.body.classList.remove('menu-open');
        }

        function showAlert(type, title, message) {

            const modal = document.getElementById('customAlert');
            const icon = document.getElementById('alertIcon');
            const titleEl = document.getElementById('alertTitle');
            const msgEl = document.getElementById('alertMessage');

            icon.className = 'alert-icon ' + type;

            if (type === 'success') {
                icon.innerHTML = '<i class="fas fa-circle-check"></i>';
            } else if (type === 'error') {
                icon.innerHTML = '<i class="fas fa-circle-xmark"></i>';
            } else {
                icon.innerHTML = '<i class="fas fa-triangle-exclamation"></i>';
            }

            titleEl.textContent = title;
            msgEl.textContent = message;

            modal.classList.remove('hidden');
        }

        function closeAlert() {
            document.getElementById('customAlert').classList.add('hidden');
        }

        const chatWidget = document.getElementById('chatWidget');
        const openBtn = document.getElementById('openChatBtn');
        const chatBody = document.getElementById('chatBody');
        const chatInput = document.getElementById('chatInput');
        const chatHeader = document.getElementById('chatHeader');

        openBtn.onclick = () => {
            chatWidget.classList.remove('hidden');
            openBtn.style.display = 'none';
        };

        function toggleChat() {
            chatWidget.classList.add('hidden');
            openBtn.style.display = 'block';
        }

        // Append chat messages
        function appendMessage(role, resp) {
            const div = document.createElement('div');
            div.className = 'chatMessage';

            if (role === 'You') {
                div.innerHTML = `<b>You</b><div class="chatSection">${resp}</div>`;
            } else {
                // Parse sections like [PREDEFINED], [DOCUMENT], [URL]
                const sections = resp.split(/\[([A-Z]+)\]/).filter(s => s.trim());
                let html = '';
                if (sections.length >= 2) {
                    for (let i = 0; i < sections.length; i += 2) {
                        let type = sections[i], text = sections[i + 1] || '';
                        let cls = '';
                        if (type === 'PREDEFINED') cls = 'predefined';
                        if (type === 'DOCUMENT') cls = 'document';
                        if (type === 'URL') cls = 'url';
                        html += `<div class="chatSection ${cls}">${text}</div>`;
                    }
                } else {
                    html = `<div class="chatSection predefined">${resp}</div>`;
                }
                div.innerHTML = `<b>AI</b>${html}`;
            }

            chatBody.appendChild(div);
            chatBody.scrollTop = chatBody.scrollHeight;
        }

        async function sendChat() {
            const msg = chatInput.value.trim();
            if (!msg) return;

            appendMessage('You', msg);
            chatInput.value = '';

            // Show typing animation
            showTypingIndicator();

            try {
                const res = await fetch(API_BASE + '/api/ai-chat/ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        message: msg,
                        userId: 1
                    })
                });

                removeTypingIndicator();

                if (!res.ok)
                    throw new Error('API Error');

                const data = await res.json();

                appendMessage('AI', data.reply);

            } catch (err) {

                removeTypingIndicator();

                console.error(err);

                showAlert(
                    'error',
                    'Connection Failed',
                    'Unable to connect to AI service. Please check your API.'
                );

                appendMessage(
                    'AI',
                    '⚠️ Unable to connect to AI service.'
                );
            }
        }

        // Press Enter to send
        chatInput.addEventListener('keydown', e => {
            if (e.key === 'Enter') sendChat();
        });

        function showTypingIndicator() {
            const div = document.createElement('div');
            div.className = 'chatMessage';
            div.id = 'typingIndicator';

            div.innerHTML = `
        <b>AI</b>
        <div class="chatSection typing">
            <span></span>
            <span></span>
            <span></span>
        </div>
    `;

            chatBody.appendChild(div);
            chatBody.scrollTop = chatBody.scrollHeight;
        }

        function removeTypingIndicator() {
            const typing = document.getElementById('typingIndicator');
            if (typing) typing.remove();
        }

        // Drag functionality for chat widget
        let drag = false, ox = 0, oy = 0;
        chatHeader.onmousedown = e => {
            drag = true;
            ox = e.clientX - chatWidget.offsetLeft;
            oy = e.clientY - chatWidget.offsetTop;
        };
        document.onmouseup = () => drag = false;
        document.onmousemove = e => {
            if (!drag) return;
            chatWidget.style.left = e.clientX - ox + 'px';
            chatWidget.style.top = e.clientY - oy + 'px';
        };

        // Logo ripple effect
        function logoRipple(e) {
            const bg = e.currentTarget.querySelector('.logo-bg');
            const ripple = document.createElement('span');
            ripple.style.position = 'absolute';
            ripple.style.width = '20px';
            ripple.style.height = '20px';
            ripple.style.borderRadius = '50%';
            ripple.style.background = 'rgba(255,255,255,.6)';
            ripple.style.left = e.offsetX + 'px';
            ripple.style.top = e.offsetY + 'px';
            ripple.style.transform = 'scale(1)';
            ripple.style.opacity = '1';
            ripple.style.transition = 'all .6s ease';
            bg.appendChild(ripple);
            setTimeout(() => { ripple.style.transform = 'scale(15)'; ripple.style.opacity = '0'; }, 10);
            setTimeout(() => ripple.remove(), 600);
        }
    </script>
</body>

</html>