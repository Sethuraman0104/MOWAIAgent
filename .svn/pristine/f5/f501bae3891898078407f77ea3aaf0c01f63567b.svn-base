:root {
    --red: #d50f1b;
    --red-dark: #a80717;
    --white: #ffffff;
    --silver: #d3d4d9;
    --dark: #141725;

    --bg: #f4f6f9;
    --card: #ffffff;
    --text: #141725;
    --muted: #6b7280;
    --border: #e5e7eb;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
}

/* =====================================
   PAGE
===================================== */

.page {
    display: flex;
    min-height: 100vh;
    background: var(--bg);
}

@media (max-width:1024px) {
    .page {
        flex-direction: column;
    }
}

/* =====================================
   SIDEBAR
===================================== */

.sidebar {
    width: 300px;
    min-width: 300px;
    background: #fff;
    border-right: 1px solid var(--border);
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

/* =====================================
   LOGO PANEL
===================================== */
.brand-card {

    background: linear-gradient(135deg,
            var(--dark),
            #20263b);

    border-radius: 20px;

    padding: 20px;

    text-align: center;

    margin-bottom: 25px;
}

.logo-shell {

    width: 100%;

    min-height: 120px;

    padding: 15px;

    margin: 0 auto 18px;

    border-radius: 16px;

    background: #ffffff;

    display: flex;
    align-items: center;
    justify-content: center;

    overflow: hidden;
}

.logo-shell img {

    width: 100%;
    max-width: 180px;

    height: auto;

    object-fit: contain;

    display: block;
}

.brand-card h2 {
    color: #fff;
    font-size: 22px;
    margin-bottom: 6px;
}

.brand-card p {
    color: #d1d5db;
    font-size: 13px;
    line-height: 1.5;
}

@media(max-width:900px) {

    .brand-card {
        display: flex;
        align-items: center;
        gap: 20px;
        text-align: left;
    }

    .logo-shell {

        width: 140px;
        min-width: 140px;

        min-height: 90px;

        margin: 0;
    }

    .logo-shell img {
        max-width: 120px;
    }

    .brand-card p {
        display: none;
    }
}

@media(max-width:768px) {

    .brand-card {

        display: flex;
        align-items: center;
        gap: 15px;

        text-align: left;

        padding: 18px;
    }

    .logo-shell {

        width: 110px;
        min-width: 110px;

        min-height: 70px;
    }

    .logo-shell img {
        max-width: 90px;
    }

    .brand-card h2 {
        font-size: 20px;
    }

    .brand-card p {
        font-size: 12px;
    }
}

/* =====================================
   NAVIGATION
===================================== */

nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.nav-card {

    display: flex;
    align-items: center;
    gap: 14px;

    text-decoration: none;

    padding: 14px;

    border-radius: 14px;

    color: var(--text);

    border: 1px solid transparent;

    transition: .25s ease;
}

.nav-card:hover {

    background: #fff5f5;

    border-color: #ffd7db;
}

.nav-card i {

    width: 42px;
    height: 42px;

    display: flex;
    align-items: center;
    justify-content: center;

    border-radius: 12px;

    background: #fff1f2;

    color: var(--red);

    font-size: 18px;
}

.nav-card.active {

    background: #fff1f2;

    color: #111827;

    border: 1px solid #ffd7db;
}

.nav-card.active i {

    background: var(--red);

    color: #fff;
}

.nav-card strong {
    display: block;
    font-size: 14px;
}

.nav-card small {
    color: var(--muted);
    font-size: 12px;
}

/* =====================================
   MAIN CONTENT
===================================== */

.content {
    flex: 1;
    padding: 25px;
    min-width: 0;
}

@media(max-width:768px) {

    .content {
        padding: 15px;
    }
}

@media(max-width:768px) {

    nav {

        display: grid;

        grid-template-columns:
            repeat(2, 1fr);

        gap: 10px;
    }

    .nav-card {

        flex-direction: column;

        text-align: center;

        gap: 8px;

        padding: 15px;
    }

    .nav-card small {
        display: none;
    }
}

/* =====================================
   TOP BAR
===================================== */

.topbar {

    display: flex;

    justify-content: space-between;

    align-items: center;

    gap: 20px;

    flex-wrap: wrap;

    background: #fff;

    border-radius: 18px;

    padding: 18px 24px;
    border: 1px solid var(--border);
    margin-bottom: 20px;
}

.topbar h1 {
    font-size: 28px;
}

@media(max-width:768px) {

    .topbar {
        padding: 18px;
    }

    .topbar h1 {
        font-size: 22px;
    }
}

.topbar p {
    color: var(--muted);
    font-size: 13px;
    margin-top: 3px;
}

.ai-status {

    border: none;

    background: #ecfdf5;

    color: #166534;

    padding: 10px 18px;

    border-radius: 50px;

    font-size: 13px;
    font-weight: 600;

    display: flex;
    align-items: center;
    gap: 8px;
}

.ai-status span {

    width: 8px;
    height: 8px;

    border-radius: 50%;

    background: #22c55e;
}

/* =====================================
   HERO
===================================== */

.hero {

    margin-top: 20px;

    background: #fff;

    border-radius: 20px;

    padding: 30px;

    border: 1px solid var(--border);
}

.tag {

    display: inline-flex;

    align-items: center;

    gap: 8px;

    padding: 8px 14px;

    border-radius: 50px;

    background: #fff1f2;

    color: var(--red);

    font-size: 13px;

    font-weight: 600;
}

.hero h2 {

    margin-top: 15px;

    font-size: 34px;

    color: var(--dark);

    line-height: 1.3;
}

.hero p {

    margin-top: 15px;

    max-width: 850px;

    color: var(--muted);

    font-size: 15px;

    line-height: 1.8;
}

.hero-right {
    display: none;
}

/* =====================================
   DASHBOARD CARDS
===================================== */

.cards {

    margin-top: 20px;

    display: grid;

    grid-template-columns:
        repeat(auto-fit, minmax(260px, 1fr));

    gap: 18px;
}

.dashboard-card {

    text-decoration: none;

    background: #fff;

    color: var(--text);

    border: 1px solid var(--border);

    border-radius: 18px;

    padding: 24px;

    transition: .25s ease;
}

.dashboard-card:hover {

    border-color: #f6a0a8;

    transform: translateY(-4px);

    box-shadow:
        0 8px 24px rgba(0, 0, 0, .06);
}

.dashboard-card i {

    width: 55px;
    height: 55px;

    border-radius: 14px;

    background: #fff1f2;

    color: var(--red);

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 22px;

    margin-bottom: 16px;
}

.dashboard-card h3 {

    font-size: 18px;

    margin-bottom: 8px;
}

.dashboard-card p {

    color: var(--muted);

    font-size: 14px;

    line-height: 1.6;
}

/* =====================================
   CHAT BUTTON
===================================== */

#openChatBtn {

    position: fixed;

    bottom: 25px;
    right: 25px;

    width: 58px;
    height: 58px;

    border: none;

    border-radius: 50%;

    background: var(--red);

    color: #fff;

    cursor: pointer;

    font-size: 20px;

    box-shadow:
        0 10px 25px rgba(213, 15, 27, .25);
}

#openChatBtn:hover {
    background: var(--red-dark);
}

.hidden {
    display: none !important;
}

/* =====================================
   CHAT WINDOW
===================================== */

#chatWidget {

    position: fixed;

    right: 25px;
    bottom: 95px;

    width: 420px;

    max-width: calc(100vw - 20px);

    height: 650px;

    max-height: 85vh;

    background: #fff;

    border-radius: 18px;

    border: 1px solid var(--border);

    overflow: hidden;

    display: flex;
    flex-direction: column;

    box-shadow:
        0 20px 50px rgba(0, 0, 0, .15);
}

/* =====================================
   CHAT HEADER
===================================== */

#chatHeader {

    background: var(--dark);

    color: #fff;

    padding: 14px 18px;

    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chatBrand {

    display: flex;
    align-items: center;
    gap: 10px;
}

.chatLogo {

    width: 40px;
    height: 40px;

    border-radius: 10px;

    background: rgba(255, 255, 255, .15);

    display: flex;
    align-items: center;
    justify-content: center;
}

#chatHeader button {

    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    font-size: 18px;
}

/* =====================================
   CHAT BODY
===================================== */

#chatBody {

    flex: 1;

    overflow: auto;

    padding: 15px;

    background: #f9fafb;
}

.chatMessage {
    margin-bottom: 14px;
}

.chatMessage b {

    display: block;

    margin-bottom: 6px;

    color: var(--red);

    font-size: 13px;
}

.chatSection {

    background: #fff;

    border: 1px solid #eee;

    border-radius: 12px;

    padding: 12px;

    line-height: 1.7;

    font-size: 14px;
}

@media(max-width:768px) {

    #chatWidget {

        position: fixed;

        top: 70px;
        /* mobile header height */

        left: 0;
        right: 0;
        bottom: 0;

        width: 100%;

        height: calc(100vh - 70px);

        max-height: none;

        border-radius: 0;

        z-index: 10000;
    }

    #openChatBtn {

        width: 60px;
        height: 60px;

        right: 15px;
        bottom: 15px;
    }
}

.predefined {
    border-left: 4px solid var(--red);
}

.document {
    border-left: 4px solid #0284c7;
}

.url {
    border-left: 4px solid #16a34a;
}

/* =====================================
   CHAT INPUT
===================================== */

#chatInputContainer {

    display: flex;

    gap: 10px;

    padding: 12px;

    border-top: 1px solid var(--border);

    background: #fff;
}

#chatInput {

    flex: 1;

    border: 1px solid #ddd;

    border-radius: 12px;

    padding: 12px;

    font-size: 14px;
}

#chatInput:focus {

    outline: none;

    border-color: var(--red);
}

#chatInputContainer button {

    width: 48px;
    height: 48px;

    border: none;

    border-radius: 12px;

    background: var(--red);

    color: #fff;

    cursor: pointer;
}

/* =====================================
   MOBILE
===================================== */

@media(max-width:900px) {

    .page {
        flex-direction: column;
    }

    .sidebar {
        width: 100%;
    }

    #chatWidget {
        width: 95%;
        right: 2.5%;
    }
}

/* ================= CUSTOM ALERT ================= */

.custom-alert {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, .55);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    animation: fadeIn .25s ease;
}

.custom-alert.hidden {
    display: none;
}

.alert-box {
    width: 90%;
    max-width: 420px;
    padding: 30px;
    border-radius: 24px;
    background: rgba(255, 255, 255, .12);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, .15);
    box-shadow: 0 25px 60px rgba(0, 0, 0, .45);
    text-align: center;
    animation: popupScale .28s ease;
    color: #fff;
}

.alert-icon {
    width: 85px;
    height: 85px;
    margin: auto auto 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
}

/* Success */
.alert-icon.success {
    background: linear-gradient(135deg, #11998e, #38ef7d);
    box-shadow: 0 10px 30px rgba(56, 239, 125, .45);
}

/* Error */
.alert-icon.error {
    background: linear-gradient(135deg, #ff416c, #ff4b2b);
    box-shadow: 0 10px 30px rgba(255, 75, 43, .45);
}

/* Warning */
.alert-icon.warning {
    background: linear-gradient(135deg, #f7971e, #ffd200);
    box-shadow: 0 10px 30px rgba(255, 210, 0, .45);
}

.alert-box h3 {
    margin: 0;
    font-size: 28px;
    font-weight: 700;
}

.alert-box p {
    margin: 14px 0 25px;
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, .88);
}

.alert-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
}

.alert-btn {
    border: none;
    padding: 12px 28px;
    border-radius: 14px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: .3s;
}

.alert-btn.ok {
    background: linear-gradient(90deg, #6a11cb, #2575fc);
    color: #fff;
}

.alert-btn.cancel {
    background: rgba(255, 255, 255, .12);
    color: #fff;
}

.alert-btn:hover {
    transform: translateY(-2px) scale(1.03);
}

@keyframes popupScale {
    from {
        transform: scale(.75);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

/* ================= LOADING OVERLAY ================= */

.loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.75);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 99999;
    animation: fadeIn .25s ease;
}

.loading-overlay.hidden {
    display: none;
}

.loading-box {
    width: 320px;
    padding: 35px 30px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
    text-align: center;
    color: #fff;
    backdrop-filter: blur(15px);
}

.loading-box h3 {
    margin-top: 20px;
    margin-bottom: 10px;
    font-size: 22px;
    font-weight: 700;
}

.loading-box p {
    font-size: 14px;
    opacity: .85;
    line-height: 1.6;
}

.loading-spinner {
    width: 75px;
    height: 75px;
    margin: auto;
    border-radius: 50%;
    border: 6px solid rgba(255, 255, 255, 0.15);
    border-top: 6px solid #4f9cff;
    animation: spin .9s linear infinite;
    box-shadow: 0 0 30px rgba(79, 156, 255, .5);
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }

    to {
        opacity: 1;
    }
}

.sidebar-footer {

    margin-top: 25px;

    flex-shrink: 0;
    margin-top: auto;
}

.footer-divider {

    height: 1px;

    background: #e5e7eb;

    margin-bottom: 20px;
}

.app-info {

    background: linear-gradient(135deg,
            #fafafa,
            #ffffff);

    border: 1px solid #ececec;

    border-radius: 16px;

    padding: 16px;
}

.app-meta {

    font-size: 12px;

    color: #6b7280;

    margin-bottom: 8px;

    line-height: 1.5;
}

/* ===========================
   MOBILE LAYOUT
=========================== */

.mobile-header,
.mobile-overlay {
    display: none;
}

@media (max-width:900px) {

    /* ===========================
       HEADER
    ============================ */

    .mobile-header {

        display: flex;

        position: fixed;

        top: 0;
        left: 0;
        right: 0;

        height: 70px;

        background: #fff;

        border-bottom: 1px solid #e5e7eb;

        z-index: 9999;

        padding: 0 12px;

        align-items: center;

        gap: 12px;

        overflow: hidden;

        box-shadow:
            0 4px 15px rgba(0, 0, 0, .05);
    }

    .mobile-menu-btn {

        width: 42px;
        height: 42px;

        min-width: 42px;

        border: none;

        border-radius: 12px;

        background: #fff1f2;

        color: #d50f1b;

        cursor: pointer;

        display: flex;
        align-items: center;
        justify-content: center;

        flex-shrink: 0;
    }

    /* ===========================
       BRAND AREA
    ============================ */

    .mobile-brand {

        flex: 1;

        min-width: 0;

        display: flex;

        align-items: center;

        gap: 10px;

        overflow: hidden;
    }

    .mobile-brand img {

        width: 42px;
        height: 42px;

        object-fit: contain;

        flex-shrink: 0;
    }

    .mobile-brand>div {

        flex: 1;

        min-width: 0;

        overflow: hidden;
    }

    .mobile-brand h3 {

        margin: 0;

        font-size: 16px;

        font-weight: 700;

        color: var(--dark);

        line-height: 1.2;

        white-space: nowrap;

        overflow: hidden;

        text-overflow: ellipsis;
    }

    .mobile-brand span {

        display: block;

        font-size: 10px;

        color: #6b7280;

        line-height: 1.2;

        white-space: nowrap;

        overflow: hidden;

        text-overflow: ellipsis;
    }

    /* ===========================
       PAGE
    ============================ */

    .page {

        display: block;

        padding-top: 70px;
    }

    .content {

        width: 100%;

        margin: 0;

        padding: 15px;
    }

    /* ===========================
       SIDEBAR
    ============================ */

    .sidebar {

        position: fixed;

        top: 70px;

        left: -320px;

        width: 300px;

        height: calc(100vh - 70px);

        background: #fff;

        overflow-y: auto;

        z-index: 9998;

        transition: left .3s ease;

        box-shadow:
            0 10px 40px rgba(0, 0, 0, .15);
    }

    .sidebar.show {
        left: 0;
    }

    /* ===========================
       OVERLAY
    ============================ */

    .mobile-overlay {

        display: block;

        position: fixed;

        inset: 0;

        background: rgba(0, 0, 0, .45);

        z-index: 9997;

        opacity: 0;

        visibility: hidden;

        transition: .3s ease;
    }

    .mobile-overlay.show {

        opacity: 1;

        visibility: visible;
    }
}

/* Extra Small Phones */

@media (max-width:480px) {

    .mobile-header {
        padding: 0 10px;
    }

    .mobile-brand img {
        width: 38px;
        height: 38px;
    }

    .mobile-brand h3 {
        font-size: 15px;
    }

    .mobile-brand p {
        font-size: 40px;
    }
}

body.menu-open {
    overflow: hidden;
}

.typing {
    display: flex;
    align-items: center;
    gap: 5px;
    min-height: 25px;
}

.typing span {
    width: 8px;
    height: 8px;
    background: #666;
    border-radius: 50%;
    animation: bounce 1.4s infinite ease-in-out;
}

.typing span:nth-child(2) {
    animation-delay: .2s;
}

.typing span:nth-child(3) {
    animation-delay: .4s;
}

@keyframes bounce {

    0%,
    80%,
    100% {
        transform: scale(0.5);
        opacity: .5;
    }

    40% {
        transform: scale(1);
        opacity: 1;
    }
}

.topbar-right {
    display: flex;
    align-items: center;
    gap: 15px;
}

/* USER CARD */
.user-profile {
    display: flex;
    align-items: center;
    gap: 12px;

    padding: 10px 16px;

    border-radius: 18px;

    background: linear-gradient(135deg,
            rgba(213, 15, 27, .08),
            rgba(255, 255, 255, .95));

    border: 1px solid rgba(213, 15, 27, .15);

    backdrop-filter: blur(12px);

    box-shadow:
        0 8px 25px rgba(213, 15, 27, .12);

    transition: all .3s ease;
}

.user-profile:hover {
    transform: translateY(-2px);

    box-shadow:
        0 12px 30px rgba(213, 15, 27, .22);
}

/* AVATAR */
.user-avatar {
    position: relative;

    width: 44px;
    height: 44px;

    border-radius: 14px;

    display: flex;
    align-items: center;
    justify-content: center;

    background: linear-gradient(135deg,
            #d50f1b,
            #a80717);

    color: #ffffff;

    font-size: 18px;

    box-shadow:
        0 6px 16px rgba(213, 15, 27, .35);
}

/* ONLINE DOT */
.user-online {
    position: absolute;

    right: -2px;
    bottom: -2px;

    width: 12px;
    height: 12px;

    background: #22c55e;

    border: 2px solid #ffffff;

    border-radius: 50%;
}

/* USER DETAILS */
.user-details {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
}

.user-details strong {
    color: #141725;
    font-size: 14px;
    font-weight: 700;
}

.user-details small {
    color: #6b7280;
    font-size: 12px;
    font-weight: 500;
}

/* MOBILE */
@media(max-width:768px) {

    .topbar-right {
        width: 100%;
        justify-content: space-between;
        margin-top: 12px;
    }

    .user-profile {
        flex: 1;
        min-width: 0;
    }

    .user-details strong {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
}

.auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a, #1e293b, #334155);
    font-family: 'Segoe UI', sans-serif;
    overflow: hidden;
    position: relative;
}

.auth-page::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: rgba(59, 130, 246, .15);
    border-radius: 50%;
    filter: blur(80px);
    top: -150px;
    right: -150px;
}

.auth-page::after {
    content: '';
    position: absolute;
    width: 450px;
    height: 450px;
    background: rgba(16, 185, 129, .12);
    border-radius: 50%;
    filter: blur(90px);
    bottom: -120px;
    left: -120px;
}

.auth-card {
    width: 90%;
    max-width: 650px;
    background: rgba(255, 255, 255, .08);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, .15);
    border-radius: 24px;
    padding: 50px;
    text-align: center;
    color: #fff;
    position: relative;
    z-index: 2;
    box-shadow: 0 20px 60px rgba(0, 0, 0, .35);
}

.auth-logo {
    width: 110px;
    height: 110px;
    margin: auto;
    margin-bottom: 25px;
    border-radius: 24px;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(0, 0, 0, .2);
}

.auth-logo img {
    width: 80px;
}

.auth-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: rgba(239, 68, 68, .15);
    color: #ef4444;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 42px;
}

.auth-card h1 {
    margin: 0;
    font-size: 34px;
    font-weight: 700;
}

.auth-card h2 {
    margin: 15px 0;
    color: #fca5a5;
    font-size: 22px;
}

.auth-card p {
    color: #d1d5db;
    line-height: 1.8;
    font-size: 15px;
}

.auth-info {
    margin-top: 30px;
    background: rgba(255, 255, 255, .05);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 16px;
    padding: 18px;
    color: #cbd5e1;
    font-size: 14px;
}

.auth-footer {
    margin-top: 25px;
    color: #94a3b8;
    font-size: 13px;
}

.auth-btn {
    margin-top: 25px;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    border: none;
    color: #fff;
    padding: 12px 28px;
    border-radius: 12px;
    cursor: pointer;
    font-size: 15px;
    font-weight: 600;
    transition: .3s;
}

.auth-btn:hover {
    transform: translateY(-2px);
}

.page-header {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}

.header-right {
    display: flex;
    justify-content: space-between; /* KEY FIX */
    align-items: center;
    width: 100%;
}

.header-left h2 {
    margin: 0;
    font-size: 22px;
}

/* push button slightly right aligned */
.header-right .btn {
    margin-left: auto;
}

/* spacing under header */
.search-box {
    margin-top: 10px;
    margin-bottom: 20px;
    display: flex;
    gap: 10px;
}

/* ================= BUTTONS ================= */
.btn {
    padding: 10px 14px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.btn-primary {
    background: #0284c7;
    color: #fff;
}

.btn-primary:hover {
    background: #111827;
    transform: translateY(-2px);
}

.btn-back {
    background: #f3f4f6;
    color: #111827;
    border: 1px solid #d1d5db;
}

.btn-back:hover {
    background: #e5e7eb;
    transform: translateY(-2px);
}

.btn-group-left,
.btn-group-right {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* ================= SEARCH ================= */
.search-box {
    margin-bottom: 15px;
    display: flex;
    gap: 10px;
}

.search-box input {
    flex: 1;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid var(--border);
}

/* ================= TABLE ================= */
table {
    width: 100%;
    border-collapse: collapse;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
}

thead {
    background: #141725;
    color: #fff;
}

th,
td {
    padding: 12px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
}

/* Hover only on data rows */
tbody tr {
    transition: background 0.2s ease;
}

tbody tr:hover {
    background: #f9fafb;
}

/* ================= STATUS ================= */
.status {
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.active {
    background: #dcfce7;
    color: #16a34a;
}

.inactive {
    background: #fee2e2;
    color: #d50f1b;
}

/* ================= ACTION BUTTONS (MODERN UI) ================= */

.action-btn {
    padding: 7px 12px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid transparent;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
}

/* hover lift + glow */
.action-btn:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
}

/* click effect */
.action-btn:active {
    transform: translateY(0px) scale(0.98);
}

/* icon animation */
.action-btn i {
    transition: transform 0.3s ease;
}

.action-btn:hover i {
    transform: rotate(-8deg) scale(1.1);
}

/* ================= EDIT ================= */
.edit {
    background: linear-gradient(135deg, #e0f2fe, #dbeafe);
    color: #0284c7;
    border-color: #93c5fd;
}

.edit:hover {
    background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    box-shadow: 0 8px 20px rgba(2, 132, 199, 0.25);
}

/* ================= DELETE ================= */
.delete {
    background: linear-gradient(135deg, #fee2e2, #fecaca);
    color: #dc2626;
    border-color: #fca5a5;
}

.delete:hover {
    background: linear-gradient(135deg, #fecaca, #fca5a5);
    box-shadow: 0 8px 20px rgba(220, 38, 38, 0.25);
}

/* ================= TOGGLE ================= */
.toggle {
    background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
    color: #111827;
    border-color: #d1d5db;
}

.toggle:hover {
    background: linear-gradient(135deg, #e5e7eb, #d1d5db);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.15);
}

/* ================= RIPPLE EFFECT ================= */
.action-btn::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background: rgba(255, 255, 255, 0.3);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.action-btn:active::after {
    opacity: 1;
    transition: 0s;
}
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(20, 23, 37, 0.75);
    backdrop-filter: blur(6px);
    justify-content: center;
    align-items: center;
}

.modal-content {
    background: #ffffff;
    padding: 24px;
    width: 420px;
    border-radius: 16px;
    border-top: 4px solid #d50f1b;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    animation: popIn 0.25s ease;
}

@keyframes popIn {
    from {
        transform: scale(0.9);
        opacity: 0;
    }

    to {
        transform: scale(1);
        opacity: 1;
    }
}

.modal-content h3 {
    margin: 0 0 15px 0;
    color: #141725;
    font-size: 18px;
}

.modal-content input {
    width: 100%;
    padding: 11px 12px;
    margin-bottom: 12px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-size: 14px;
    transition: 0.2s;
}

.modal-content input:focus {
    border-color: #0284c7;
    outline: none;
    box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.15);
}

.modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 10px;
}

.module-badge{
    background:#e0f2fe;
    color:#0284c7;
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    font-weight:600;
}

.action-badge{
    padding:6px 12px;
    border-radius:20px;
    font-size:12px;
    font-weight:600;
}

.action-badge.login{
    background:#dcfce7;
    color:#16a34a;
}

.action-badge.logout{
    background:#fee2e2;
    color:#dc2626;
}

.action-badge.insert{
    background:#dbeafe;
    color:#2563eb;
}

.action-badge.update{
    background:#fef3c7;
    color:#d97706;
}

.action-badge.delete{
    background:#fee2e2;
    color:#dc2626;
}

/* ================= EMPTY STATE ================= */

.empty-state{
    text-align:center;
    padding:50px 20px !important;
    background:#fff;
}

.empty-box{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:12px;
}

.empty-box i{
    font-size:60px;
    color:#cbd5e1;
}

.empty-box h3{
    margin:0;
    font-size:22px;
    color:#334155;
}

.empty-box p{
    margin:0;
    color:#64748b;
    font-size:14px;
    max-width:450px;
}

.empty-box{
    background:linear-gradient(
        135deg,
        #f8fafc,
        #eef6ff
    );
    border:1px dashed #cbd5e1;
    border-radius:18px;
    padding:40px;
}

/* ================= EMPTY TABLE STATE ================= */

.empty-state{
    text-align:center;
    padding:60px 20px !important;
    background:#fff;
}

.empty-content{
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
}

.empty-icon{
    font-size:48px;
    color:#cbd5e1;
    margin-bottom:15px;
}

.empty-content h3{
    margin:0;
    color:#334155;
    font-size:20px;
    font-weight:600;
}

.empty-content p{
    margin-top:8px;
    color:#64748b;
    font-size:14px;
}

.pagination-container {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top:20px;
    padding:12px 0;
    flex-wrap:wrap;
    gap:10px;
}

.pagination-info {
    font-size:14px;
    color:#666;
}

.pagination-controls {
    display:flex;
    align-items:center;
    gap:10px;
}

.pagination-controls button:disabled {
    opacity:.5;
    cursor:not-allowed;
}

#pageInfo {
    font-weight:600;
    min-width:120px;
    text-align:center;
}

.query-card {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 18px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 3px 12px rgba(0,0,0,.05);
}

.query-header {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:15px;
}

.query-id {
    font-weight:700;
    color:#667085;
}

.query-date {
    color:#98a2b3;
    font-size:13px;
}

.user-question {
    background:#f8fafc;
    border-left:4px solid #2563eb;
    padding:15px;
    border-radius:10px;
    margin-bottom:15px;
}

.ai-response {
    background:#f0fdf4;
    border-left:4px solid #22c55e;
    padding:15px;
    border-radius:10px;
    margin-bottom:15px;
}

.query-label {
    font-weight:700;
    margin-bottom:8px;
}

.doc-ids {
    font-size:13px;
    color:#6b7280;
    margin-top:10px;
}

.feedback-badge {
    display:inline-block;
    padding:5px 12px;
    border-radius:20px;
    font-size:12px;
    font-weight:600;
}

.feedback-positive {
    background:#dcfce7;
    color:#166534;
}

.feedback-negative {
    background:#fee2e2;
    color:#991b1b;
}

.feedback-none {
    background:#f3f4f6;
    color:#6b7280;
}

.query-text,
.response-text {
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.6;
}

.query-footer {
    margin-top: 15px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}

.response-type-badge,
.confidence-badge,
.chat-id-badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.badge-document {
    background: #e8f5e9;
    color: #2e7d32;
}

.badge-url {
    background: #e3f2fd;
    color: #1565c0;
}

.badge-internet {
    background: #fff3e0;
    color: #ef6c00;
}

.badge-default {
    background: #f1f3f4;
    color: #555;
}

.confidence-badge,
.chat-id-badge {
    background: #f5f5f5;
    color: #444;
}