<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOW AI Control Center - Predefined Questions</title>
    <link rel="icon" type="image/png" href="assets/appicon.png">
    <link rel="stylesheet" href="css/admin.css">
    <link rel="stylesheet" href="css/predefined.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <script src="js/api.js"></script>
</head>

<body>
    <!-- MOBILE HEADER -->
    <div class="mobile-header">
        <button class="mobile-menu-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="mobile-brand">
            <img src="assets/mowlogo.png" alt="">
            <div>
                <h3>MOW AI</h3>
                <span>Knowledge Administration Platform</span>
            </div>
        </div>
    </div>

    <div class="mobile-overlay" onclick="closeSidebar()"></div>
    <div class="page">
        <aside class="sidebar">
            <div>
                <div class="brand-card">
                    <div class="logo-shell">
                        <img src="assets/mowlogo.png" alt="">
                    </div>
                    <h2>MOW AI</h2>
                    <p>
                        Knowledge Administration Platform
                    </p>
                </div>

                <nav>
                    <a href="MOWAIHome.html" class="nav-card">
                        <i class="fas fa-house"></i>
                        <div>
                            <strong>Dashboard</strong>
                            <small>Overview</small>
                        </div>
                    </a>
                    <a href="documents.html" class="nav-card">
                        <i class="fas fa-file-lines"></i>
                        <div>
                            <strong>Documents</strong>
                            <small>Training Files</small>
                        </div>
                    </a>
                    <a href="urls.html" class="nav-card">
                        <i class="fas fa-link"></i>
                        <div>
                            <strong>URLs</strong>
                            <small>Knowledge Sources</small>
                        </div>
                    </a>
                    <a href="predefined.html" class="nav-card active">
                        <i class="fas fa-circle-question"></i>
                        <div>
                            <strong>Questions</strong>
                            <small>AI Answers</small>
                        </div>
                    </a>
                </nav>
            </div>

            <!-- FOOTER -->
            <div class="sidebar-footer">
                <div class="footer-divider"></div>
                <div class="app-info">
                    <div class="app-badge">
                        <i class="fas fa-robot"></i>
                        MOW AI
                    </div>

                    <div class="app-meta">
                        Version 1.0.0
                    </div>

                    <div class="app-meta">
                        Developed by MOW ITD Team
                    </div>

                    <div class="app-meta">
                        © 2026 Ministry of Works
                    </div>
                </div>
            </div>
        </aside>

        <!-- CONTENT -->
        <main class="content">
            <div class="topbar">
                <div>
                    <h1><i class="fas fa-list-check"></i> Predefined Questions</h1>
                    <p>
                        Manage AI predefined answers and chatbot responses.
                    </p>
                </div>
                <div class="topbar-right">
                    <div class="user-profile">

                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                            <span class="user-online"></span>
                        </div>

                        <div class="user-details">
                           <strong id="loggedInFullName">Loading...</strong> 
                            <small id="loggedInUser">Authenticated User</small>
                        </div>

                    </div>

                </div>
            </div>

            <!-- STATS -->
            <div class="stats-grid">
                <div class="stat-card">
                    <i class="fas fa-circle-question"></i>
                    <div>
                        <h3 id="totalQuestions">0</h3>
                        <span>Total Questions</span>
                    </div>
                </div>
            </div>

            <!-- ADD FORM -->
            <section class="form-card">
                <div class="section-title">
                    <i class="fas fa-plus-circle"></i>
                    Add New Question
                </div>

                <div class="form-grid">
                    <input type="text" id="question" placeholder="Question">
                    <input type="text" id="answer" placeholder="Answer">
                    <input type="text" id="keywords" placeholder="Keywords (comma separated)">
                    <button class="save-btn" onclick="addPredefined()">
                        <i class="fas fa-circle-plus"></i> Add Question
                    </button>
                </div>
            </section>

            <!-- SEARCH -->
            <section class="search-card">
                <div class="section-title">
                    <i class="fas fa-search"></i>
                    Search Questions
                </div>
                <input type="text" id="searchInput" placeholder="Search questions...">
            </section>

            <!-- CARDS -->
            <section class="questions-container">
                <div id="questionsGrid" class="questions-grid">
                </div>

                <div id="emptyState" class="empty-state hidden">
                    <i class="fas fa-circle-question"></i>
                    <h3>No Questions Found</h3>
                    <p>
                        Create your first predefined answer.
                    </p>
                </div>
            </section>

            <div class="pagination">
                <button onclick="prevPage()">
                    <i class="fas fa-arrow-left"></i> Previous
                </button>

                <span id="pageInfo"></span>

                <button onclick="nextPage()">
                    Next <i class="fas fa-arrow-right"></i>
                </button>
            </div>
        </main>
    </div>

    <div id="customAlert" class="custom-alert hidden">
        <div class="alert-box">
            <div class="alert-icon success" id="alertIcon">
                <i class="fas fa-circle-check"></i>
            </div>

            <h3 id="alertTitle">Info</h3>

            <p id="alertMessage">Message</p>

            <div class="alert-actions" id="alertActions">
                <button class="alert-btn ok" onclick="closeAlert()">OK</button>
            </div>
        </div>
    </div>

    <!-- ================= LOADING OVERLAY ================= -->
    <div id="loadingOverlay" class="loading-overlay hidden">
        <div class="loading-box">

            <div class="loading-spinner"></div>

            <h3>Uploading Document...</h3>

            <p>Please wait while your document is being processed.</p>

        </div>
    </div>

    <!-- ================= SCRIPT ================= -->
    <script>
        let predefined = [];
        let currentPage = 1;
        const pageSize = 6;
        let confirmResolve;
        let loggedInUserName = "";
        let loggedInFullName = "";

        window.onload = async function () {

            try {
                const authorized = await validateLogin();

                if (authorized) {

                    await loadPredefined();

                    console.log("Predefined Q & A Loaded Successfully");
                }
            }
            catch (ex) {

                console.error("Startup Error:", ex);

                showAlert(
                    'error',
                    'Error',
                    ex.message || 'Failed to load page'
                );
            }
        };

        async function validateLogin() {

            try {

                console.log("Before Validate API");

                const response =
                    await apiGet('/api/auth/validate');

                console.log("After Validate API", response);

                loggedInUserName = response.userName || "";
                loggedInFullName = response.fullName || "";

                setAuditUser(loggedInUserName, loggedInFullName);

                console.log("========== MOW AI LOGIN ==========");
                console.log("User Name :", loggedInUserName);
                console.log("Full Name :", loggedInFullName);
                console.log("Authorized:", response.isAuthorized);
                console.log("Login Time:", new Date().toLocaleString());
                console.log("==================================");

                if (!response.isAuthorized) {

                    document.body.innerHTML = `
            <div class="auth-page">
                <div class="auth-card">

                    <div class="auth-logo">
                        <img src="../assets/mowlogo.png">
                    </div>

                    <div class="auth-icon">
                        <i class="fas fa-user-lock"></i>
                    </div>

                    <h1>Access Denied</h1>

                    <h2>You Are Not Authorized</h2>

                    <p>
                        Your Active Directory account was successfully identified,
                        however you have not been granted access to the
                        MOW AI Administration Portal.
                    </p>

                    <div class="auth-info">
                        Please contact the MOW ITD Team if you require
                        access to this application.
                    </div>

                    <div class="auth-footer">
                        Ministry of Works • MOW AI Administration Portal
                    </div>

                </div>
            </div>`;

                    return false;
                }

                const userElement =
                    document.getElementById("loggedInUser");

                const fullNameElement =
                    document.getElementById("loggedInFullName");

                if (userElement)
                    userElement.textContent =
                        loggedInUserName || "Unknown User";

                if (fullNameElement)
                    fullNameElement.textContent =
                        loggedInFullName || "Authenticated User";

                return true;
            }
            catch (e) {

                console.error(e);

                document.body.innerHTML = `
        <div class="auth-page">

            <div class="auth-card">

                <div class="auth-logo">
                    <img src="../assets/mowlogo.png">
                </div>

                <div class="auth-icon">
                    <i class="fas fa-shield-halved"></i>
                </div>

                <h1>MOW AI Control Center</h1>

                <h2>Authentication Failed</h2>

                <p>
                    We were unable to verify your identity through the Ministry of Works
                    authentication service.
                </p>

                <div class="auth-info">
                    <strong>Possible Reasons:</strong><br><br>

                    • Windows Authentication is not enabled.<br>
                    • Your Active Directory account could not be identified.<br>
                    • The MOW AI API service is unavailable.<br>
                    • Network or security restrictions prevented authentication.
                </div>

                <button class="auth-btn" onclick="location.reload()">
                    <i class="fas fa-rotate-right"></i>
                    Try Again
                </button>

                <div class="auth-footer">
                    Ministry of Works • Artificial Intelligence Platform<br>
                    Version 1.0.0
                </div>

            </div>

        </div>`;

                return false;
            }
        }

        function toggleSidebar() {
            document
                .querySelector('.sidebar')
                .classList.toggle('show');

            document
                .querySelector('.mobile-overlay')
                .classList.toggle('show');

            document.body.classList.toggle('menu-open');
        }

        function closeSidebar() {
            document
                .querySelector('.sidebar')
                .classList.remove('show');

            document
                .querySelector('.mobile-overlay')
                .classList.remove('show');

            document.body.classList.remove('menu-open');
        }

        function showAlert(type, title, message) {

            const modal = document.getElementById('customAlert');
            const icon = document.getElementById('alertIcon');
            const titleEl = document.getElementById('alertTitle');
            const msgEl = document.getElementById('alertMessage');
            const actions = document.getElementById('alertActions');

            icon.className = 'alert-icon ' + type;

            if (type === 'success') {
                icon.innerHTML = '<i class="fas fa-circle-check"></i>';
            }
            else if (type === 'error') {
                icon.innerHTML = '<i class="fas fa-circle-xmark"></i>';
            }
            else {
                icon.innerHTML = '<i class="fas fa-triangle-exclamation"></i>';
            }

            titleEl.textContent = title;
            msgEl.textContent = message;

            // RESET BUTTONS TO NORMAL ALERT MODE
            actions.innerHTML = `
        <button class="alert-btn ok" onclick="closeAlert()">
            OK
        </button>
    `;

            modal.classList.remove('hidden');
        }

        function closeAlert() {

            document.getElementById('customAlert')
                .classList.add('hidden');

            // clear any previous confirm callback
            confirmResolve = null;
        }



        function showConfirm(title, message) {
            return new Promise(resolve => {

                confirmResolve = resolve;

                document.getElementById('alertTitle').textContent = title;
                document.getElementById('alertMessage').textContent = message;

                const icon = document.getElementById('alertIcon');
                icon.className = 'alert-icon warning';
                icon.innerHTML = '<i class="fas fa-triangle-exclamation"></i>';

                const actions = document.getElementById('alertActions');

                actions.innerHTML = `
            <button class="alert-btn cancel" onclick="resolveConfirm(false)">Cancel</button>
            <button class="alert-btn ok" onclick="resolveConfirm(true)">Delete</button>
        `;

                document.getElementById('customAlert').classList.remove('hidden');
            });
        }

        function resolveConfirm(value) {
            document.getElementById('customAlert').classList.add('hidden');
            if (confirmResolve) confirmResolve(value);
        }

        /* ================= LOADING ================= */
        function showLoader(title = "Loading...", message = "Please wait...") {

            const overlay =
                document.getElementById('loadingOverlay');

            overlay.querySelector('h3').innerText = title;
            overlay.querySelector('p').innerText = message;

            overlay.classList.remove('hidden');
        }

        function hideLoader() {

            document
                .getElementById('loadingOverlay')
                .classList.add('hidden');
        }

        async function loadPredefined() {
            try {
                predefined = await apiGet('/api/chat/predefined/list');
                currentPage = 1;
                renderTable();
            } catch (e) {
                showAlert(
                    'error',
                    'Load Failed',
                    'Unable to load predefined questions.'
                );
            }
        }

        function renderTable() {

            const grid =
                document.getElementById('questionsGrid');

            const emptyState =
                document.getElementById('emptyState');

            const search =
                document.getElementById('searchInput')
                    .value.toLowerCase();

            const filtered =
                predefined.filter(p =>
                    p.question.toLowerCase().includes(search) ||
                    p.answer.toLowerCase().includes(search) ||
                    p.keywords.toLowerCase().includes(search)
                );

            document.getElementById("totalQuestions")
                .innerText = predefined.length;

            if (filtered.length === 0) {

                grid.innerHTML = '';

                emptyState.classList.remove('hidden');

                return;
            }

            emptyState.classList.add('hidden');

            const start =
                (currentPage - 1) * pageSize;

            const pageData =
                filtered.slice(start, start + pageSize);

            grid.innerHTML = '';

            pageData.forEach(p => {

                grid.innerHTML += `

        <div class="question-card">

            <div class="question-header">

                <i class="fas fa-circle-question"></i>

                <button
                    class="delete-btn"
                    onclick="deletePredefined(${p.id})">

                    <i class="fas fa-trash"></i>

                </button>

            </div>

            <h3>${p.question}</h3>

            <div class="answer-box">

                ${p.answer}

            </div>

            <div class="keywords">

                ${p.keywords}

            </div>

        </div>

        `;
            });

            const totalPages =
                Math.ceil(filtered.length / pageSize) || 1;

            document.getElementById('pageInfo')
                .innerText =
                `Page ${currentPage} of ${totalPages}`;
        }

        function nextPage() {
            const totalPages = Math.ceil(predefined.length / pageSize) || 1;
            if (currentPage < totalPages) {
                currentPage++;
                renderTable();
            }
        }

        function prevPage() {
            if (currentPage > 1) {
                currentPage--;
                renderTable();
            }
        }

        document.getElementById('searchInput').addEventListener('input', () => {
            currentPage = 1;
            renderTable();
        });

        async function addPredefined() {

            const q = document.getElementById('question').value.trim();
            const a = document.getElementById('answer').value.trim();
            const k = document.getElementById('keywords').value.trim();

            if (!q || !a) {
                return showAlert(
                    'warning',
                    'Validation Error',
                    'Question and Answer are required.'
                );
            }

            showLoader("Saving Predefined Question...");

            try {

                await apiPost(
                    '/api/chat/predefined',
                    {
                        question: q,
                        answer: a,
                        keywords: k
                    },
                    {
                        "X-Audit-User": loggedInUserName,
                        "X-Audit-FullName": loggedInFullName
                    }
                );

                document.getElementById('question').value = '';
                document.getElementById('answer').value = '';
                document.getElementById('keywords').value = '';

                await loadPredefined();

                showAlert(
                    'success',
                    'Saved Successfully',
                    'Predefined question added successfully.'
                );
            }
            catch (err) {

                console.error(err);

                showAlert(
                    'error',
                    'Save Failed',
                    err.message || 'Unable to add predefined question.'
                );
            }
            finally {

                hideLoader();
            }
        }

        async function deletePredefined(id) {

            const confirmed = await showConfirm(
                'Delete Question',
                'Are you sure you want to delete this predefined question?'
            );

            if (!confirmed)
                return;

            showLoader("Deleting Predefined Question...");

            try {

                await apiDelete(
                    `/api/chat/predefined/${id}`,
                    {
                        "X-Audit-User": loggedInUserName,
                        "X-Audit-FullName": loggedInFullName
                    }
                );

                await loadPredefined();

                showAlert(
                    'success',
                    'Deleted Successfully',
                    'Predefined question deleted successfully.'
                );
            }
            catch (err) {

                console.error(err);

                showAlert(
                    'error',
                    'Delete Failed',
                    err.message || 'Unable to delete predefined question.'
                );
            }
            finally {

                hideLoader();
            }
        }

        /* ===== Logo Ripple ===== */
        function logoRipple(e) {
            const bg = e.currentTarget.querySelector('.logo-bg');
            const ripple = document.createElement('span');

            ripple.style.position = 'absolute';
            ripple.style.width = '20px';
            ripple.style.height = '20px';
            ripple.style.borderRadius = '50%';
            ripple.style.background = 'rgba(255,255,255,.6)';
            ripple.style.left = (e.offsetX) + 'px';
            ripple.style.top = (e.offsetY) + 'px';
            ripple.style.transform = 'scale(1)';
            ripple.style.opacity = '1';
            ripple.style.transition = 'all .6s ease';

            bg.appendChild(ripple);

            setTimeout(() => {
                ripple.style.transform = 'scale(15)';
                ripple.style.opacity = '0';
            }, 10);

            setTimeout(() => ripple.remove(), 600);
        }
    </script>

</body>

</html>