<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOW AI Control Center - Manage Documents</title>
    <link rel="icon" type="image/png" href="assets/appicon.png">
    <link rel="stylesheet" href="css/admin.css">
    <link rel="stylesheet" href="css/documents.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <script src="js/api.js"></script>
</head>

<body>
    <!-- MOBILE HEADER -->
    <div class="mobile-header">

        <button class="mobile-menu-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="mobile-brand">
            <img src="assets/mowlogo.png" alt="">
            <div>
                <h3>MOW AI</h3>
                <span>Knowledge Administration Platform</span>
            </div>
        </div>

    </div>

    <div class="mobile-overlay" onclick="closeSidebar()"></div>

    <div class="page">
        <aside class="sidebar">

            <div>

                <div class="brand-card">

                    <div class="logo-shell">
                        <img src="assets/mowlogo.png" alt="">
                    </div>

                    <h2>MOW AI</h2>

                    <p>
                        Knowledge Administration Platform
                    </p>

                </div>

                <nav>

                    <a href="MOWAIHome.html" class="nav-card">
                        <i class="fas fa-house"></i>
                        <div>
                            <strong>Dashboard</strong>
                            <small>Overview</small>
                        </div>
                    </a>

                    <a href="documents.html" class="nav-card active">
                        <i class="fas fa-file-lines"></i>
                        <div>
                            <strong>Documents</strong>
                            <small>Training Files</small>
                        </div>
                    </a>

                    <a href="urls.html" class="nav-card">
                        <i class="fas fa-link"></i>
                        <div>
                            <strong>URLs</strong>
                            <small>Knowledge Sources</small>
                        </div>
                    </a>

                    <a href="predefined.html" class="nav-card">
                        <i class="fas fa-circle-question"></i>
                        <div>
                            <strong>Questions</strong>
                            <small>AI Answers</small>
                        </div>
                    </a>

                </nav>

            </div>

            <!-- FOOTER -->

            <div class="sidebar-footer">

                <div class="footer-divider"></div>

                <div class="app-info">

                    <div class="app-badge">
                        <i class="fas fa-robot"></i>
                        MOW AI
                    </div>

                    <div class="app-meta">
                        Version 1.0.0
                    </div>

                    <div class="app-meta">
                        Developed by MOW ITD Team
                    </div>

                    <div class="app-meta">
                        © 2026 Ministry of Works
                    </div>

                </div>

            </div>

        </aside>

        <!-- CONTENT -->

        <main class="content">

            <!-- TOP HEADER -->

            <div class="topbar">

                <div>

                    <h1><i class="fas fa-folder-open"></i> Document Management</h1>

                    <p>
                        Manage AI training documents and knowledge sources.
                    </p>

                </div>

                <div class="topbar-right">
                    <div class="user-profile">

                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                            <span class="user-online"></span>
                        </div>

                        <div class="user-details">
                            <strong id="loggedInFullName">Loading...</strong> 
                            <small id="loggedInUser">Authenticated User</small>
                        </div>

                    </div>

                </div>

            </div>

            <!-- UPLOAD -->
            <div class="stats-grid">

                <div class="stat-card">
                    <i class="fas fa-file-lines"></i>
                    <div>
                        <h3 id="totalDocs">0</h3>
                        <span>Total Documents</span>
                    </div>
                </div>

                <div class="stat-card">
                    <i class="fas fa-database"></i>
                    <div>
                        <h3 id="currentPageNo">1</h3>
                        <span>Current Page</span>
                    </div>
                </div>

                <div class="stat-card">
                    <i class="fas fa-magnifying-glass"></i>
                    <div>
                        <h3 id="searchResults">0</h3>
                        <span>Search Results</span>
                    </div>
                </div>

            </div>

            <section class="upload-card">

                <div class="section-title">

                    <i class="fas fa-cloud-upload-alt"></i>

                    Upload New Document

                </div>

                <div class="upload-row">

                    <div class="file-upload">

                        <input type="file" id="docFile">

                        <label for="docFile">

                            <i class="fas fa-file"></i>

                            <span class="file-text">
                                Select Document
                            </span>

                        </label>

                    </div>

                    <button class="upload-btn" onclick="uploadDocument()">
                        <i class="fas fa-upload"></i> Upload
                    </button>

                </div>

            </section>

            <!-- SEARCH -->

            <section class="search-card">

                <div class="section-title">

                    <i class="fas fa-search"></i>

                    Search Documents

                </div>

                <input type="text" id="searchInput" placeholder="Search documents...">

            </section>

            <!-- DOCUMENTS -->

            <section class="documents-container">

                <div id="documentsGrid" class="documents-grid">
                </div>

                <div id="emptyState" class="empty-state hidden">

                    <i class="fas fa-file-circle-xmark"></i>

                    <h3>No Documents Found</h3>

                    <p>
                        Upload your first AI document.
                    </p>

                </div>

            </section>

            <!-- PAGINATION -->

            <div class="pagination">

                <button onclick="prevPage()">
                    <i class="fas fa-arrow-left"></i> Previous
                </button>

                <span id="pageInfo"></span>

                <button onclick="nextPage()">
                    Next <i class="fas fa-arrow-right"></i>
                </button>

            </div>

        </main>

    </div>

    <!-- ================= CUSTOM ALERT ================= -->
    <div id="customAlert" class="custom-alert hidden">
        <div class="alert-box">

            <div class="alert-icon" id="alertIcon">
                <i class="fas fa-circle-check"></i>
            </div>

            <h3 id="alertTitle">Success</h3>

            <p id="alertMessage">
                Uploaded successfully
            </p>

            <div class="alert-actions" id="alertActions">
                <button class="alert-btn ok" onclick="closeAlert(true)">
                    OK
                </button>
            </div>

        </div>
    </div>

    <!-- ================= LOADING OVERLAY ================= -->
    <div id="loadingOverlay" class="loading-overlay hidden">
        <div class="loading-box">

            <div class="loading-spinner"></div>

            <h3>Uploading Document...</h3>

            <p>Please wait while your document is being processed.</p>

        </div>
    </div>

    <!-- ================= SCRIPT ================= -->
    <script>
        let loggedInUserName = "";
        let loggedInFullName = "";
        let documents = [];
        let currentPage = 1;
        const pageSize = 6;


        window.onload = async function () {
            try {

                showLoader(
                    "Loading Documents...",
                    "Fetching embedded documents from server."
                );

                console.log("Page Load Started");

                const authorized = await validateLogin();

                console.log("Authorized:", authorized);

                if (authorized) {

                    await loadDocuments();

                    console.log("Documents Loaded Successfully");
                }
            }
            catch (ex) {

                console.error("Startup Error:", ex);

                showAlert(
                    'error',
                    'Error',
                    ex.message || 'Failed to load page'
                );
            }
            finally {

                console.log("Hide Loading");

                hideLoader();
            }
        };

        async function validateLogin() {

            try {

                console.log("Before Validate API");

                const response =
                    await apiGet('/api/auth/validate');

                console.log("After Validate API", response);

                loggedInUserName = response.userName || "";
                loggedInFullName = response.fullName || "";

                setAuditUser(loggedInUserName, loggedInFullName);

                console.log("========== MOW AI LOGIN ==========");
                console.log("User Name :", loggedInUserName);
                console.log("Full Name :", loggedInFullName);
                console.log("Authorized:", response.isAuthorized);
                console.log("Login Time:", new Date().toLocaleString());
                console.log("==================================");

                if (!response.isAuthorized) {

                    document.body.innerHTML = `
            <div class="auth-page">
                <div class="auth-card">

                    <div class="auth-logo">
                        <img src="../assets/mowlogo.png">
                    </div>

                    <div class="auth-icon">
                        <i class="fas fa-user-lock"></i>
                    </div>

                    <h1>Access Denied</h1>

                    <h2>You Are Not Authorized</h2>

                    <p>
                        Your Active Directory account was successfully identified,
                        however you have not been granted access to the
                        MOW AI Administration Portal.
                    </p>

                    <div class="auth-info">
                        Please contact the MOW ITD Team if you require
                        access to this application.
                    </div>

                    <div class="auth-footer">
                        Ministry of Works • MOW AI Administration Portal
                    </div>

                </div>
            </div>`;

                    return false;
                }

                const userElement =
                    document.getElementById("loggedInUser");

                const fullNameElement =
                    document.getElementById("loggedInFullName");

                if (userElement)
                    userElement.textContent =
                        loggedInUserName || "Unknown User";

                if (fullNameElement)
                    fullNameElement.textContent =
                        loggedInFullName || "Authenticated User";

                return true;
            }
            catch (e) {

                console.error(e);

                document.body.innerHTML = `
        <div class="auth-page">

            <div class="auth-card">

                <div class="auth-logo">
                    <img src="../assets/mowlogo.png">
                </div>

                <div class="auth-icon">
                    <i class="fas fa-shield-halved"></i>
                </div>

                <h1>MOW AI Control Center</h1>

                <h2>Authentication Failed</h2>

                <p>
                    We were unable to verify your identity through the Ministry of Works
                    authentication service.
                </p>

                <div class="auth-info">
                    <strong>Possible Reasons:</strong><br><br>

                    • Windows Authentication is not enabled.<br>
                    • Your Active Directory account could not be identified.<br>
                    • The MOW AI API service is unavailable.<br>
                    • Network or security restrictions prevented authentication.
                </div>

                <button class="auth-btn" onclick="location.reload()">
                    <i class="fas fa-rotate-right"></i>
                    Try Again
                </button>

                <div class="auth-footer">
                    Ministry of Works • Artificial Intelligence Platform<br>
                    Version 1.0.0
                </div>

            </div>

        </div>`;

                return false;
            }
        }

        function toggleSidebar() {

            document
                .querySelector('.sidebar')
                .classList.toggle('show');

            document
                .querySelector('.mobile-overlay')
                .classList.toggle('show');

            document.body.classList.toggle('menu-open');
        }

        function closeSidebar() {

            document
                .querySelector('.sidebar')
                .classList.remove('show');

            document
                .querySelector('.mobile-overlay')
                .classList.remove('show');

            document.body.classList.remove('menu-open');
        }

        /* ================= CUSTOM ALERT ================= */

        let alertCallback = null;

        function showAlert(type, title, message, confirmMode = false) {

            const modal = document.getElementById('customAlert');
            const icon = document.getElementById('alertIcon');
            const titleEl = document.getElementById('alertTitle');
            const msgEl = document.getElementById('alertMessage');
            const actions = document.getElementById('alertActions');

            icon.className = 'alert-icon ' + type;

            if (type === 'success') {
                icon.innerHTML = '<i class="fas fa-circle-check"></i>';
            }
            else if (type === 'error') {
                icon.innerHTML = '<i class="fas fa-circle-xmark"></i>';
            }
            else {
                icon.innerHTML = '<i class="fas fa-triangle-exclamation"></i>';
            }

            titleEl.textContent = title;
            msgEl.textContent = message;

            if (confirmMode) {

                actions.innerHTML = `
            <button class="alert-btn cancel" onclick="closeAlert(false)">
                Cancel
            </button>

            <button class="alert-btn ok" onclick="closeAlert(true)">
                Confirm
            </button>
        `;
            }
            else {

                actions.innerHTML = `
            <button class="alert-btn ok" onclick="closeAlert(true)">
                OK
            </button>
        `;
            }

            modal.classList.remove('hidden');
        }

        function closeAlert(result) {

            document.getElementById('customAlert')
                .classList.add('hidden');

            if (alertCallback) {
                alertCallback(result);
                alertCallback = null;
            }
        }

        function showConfirm(title, message) {

            return new Promise(resolve => {

                alertCallback = resolve;

                showAlert(
                    'warning',
                    title,
                    message,
                    true
                );
            });
        }

        /* ================= LOADING ================= */
        function showLoader(title = "Loading...", message = "Please wait...") {

            const overlay =
                document.getElementById('loadingOverlay');

            overlay.querySelector('h3').innerText = title;
            overlay.querySelector('p').innerText = message;

            overlay.classList.remove('hidden');
        }

        function hideLoader() {

            document
                .getElementById('loadingOverlay')
                .classList.add('hidden');
        }

        async function loadDocuments() {

            // ✅ SHOW LOADER FOR DOCUMENT LIST
            showLoader(
                "Loading Documents...",
                "Fetching embedded documents from server."
            );

            try {

                documents =
                    await apiGet('/api/ai-docs/list');

                document.getElementById('totalDocs').innerText =
                    documents.length;

                currentPage = 1;

                renderTable();
            }
            catch (err) {

                console.error(err);

                showAlert(
                    'error',
                    'Load Failed',
                    'Unable to load documents from the server.'
                );
            }
            finally {

                // ✅ ALWAYS HIDE LOADER
                hideLoader();
            }
        }

        function renderTable() {

            const grid =
                document.getElementById('documentsGrid');

            const emptyState =
                document.getElementById('emptyState');

            const search =
                document.getElementById('searchInput')
                    .value.toLowerCase();

            const filtered =
                documents.filter(d =>
                    d.title.toLowerCase().includes(search)
                );

            document.getElementById('totalDocs').innerText =
                filtered.length;

            document.getElementById('searchResults').innerText =
                filtered.length;

            document.getElementById('currentPageNo').innerText =
                currentPage;

            if (filtered.length === 0) {

                grid.innerHTML = '';

                emptyState.classList.remove('hidden');

                document.getElementById('pageInfo')
                    .innerText = '';

                return;
            }

            emptyState.classList.add('hidden');

            const start =
                (currentPage - 1) * pageSize;

            const pageData =
                filtered.slice(
                    start,
                    start + pageSize
                );

            grid.innerHTML = '';

            pageData.forEach(d => {

                grid.innerHTML += `

        <div class="document-card">

            <div class="document-icon">
                <i class="fas fa-file-alt"></i>
            </div>

            <div class="document-content">

                <h3>${d.title}</h3>

                <p>
                    ${new Date(d.createdAt)
                        .toLocaleString()}
                </p>

            </div>

            <button
                class="delete-btn"
                onclick="deleteDocument(${d.documentId})"
            >
                <i class="fas fa-trash"></i>
            </button>

        </div>

        `;
            });

            const totalPages =
                Math.ceil(filtered.length / pageSize) || 1;

            document.getElementById('pageInfo')
                .innerText =
                `Page ${currentPage} of ${totalPages}`;
        }

        function nextPage() {
            currentPage++;
            renderTable();
        }

        function prevPage() {
            if (currentPage > 1) {
                currentPage--;
                renderTable();
            }
        }

        document.getElementById('searchInput').addEventListener('input', () => {
            currentPage = 1;
            renderTable();
        });

        async function uploadDocument() {

            const fileInput = document.getElementById('docFile');
            const file = fileInput.files[0];

            if (!file) {

                showAlert(
                    'warning',
                    'No File Selected',
                    'Please choose a document first.'
                );

                return;
            }

            const formData = new FormData();
            formData.append('file', file);

            showLoader();

            try {

                await apiPostForm('/api/ai-docs/upload', formData, {
                    headers: {
                        "X-Audit-User": loggedInUserName,
                        "X-Audit-FullName": loggedInFullName
                    }
                });

                hideLoader();

                showAlert('success', 'Upload Complete', 'Document uploaded successfully.');

                // ✅ RESET FILE INPUT
                const fileText = document.querySelector('.file-text');
                const fileWrap = document.querySelector('.file-upload');

                fileInput.value = '';
                fileText.textContent = 'Choose Document';
                fileWrap.classList.remove('selected');

                loadDocuments();
            }
            catch (err) {

                hideLoader();
                showAlert('error', 'Upload Failed', 'Unable to upload document.');
            }
        }

        async function deleteDocument(id) {

            const confirmed = await showConfirm(
                'Delete Document',
                'Are you sure you want to delete this document?'
            );

            if (!confirmed)
                return;

            showLoader("Deleting Document...");

            try {

                // ✅ USE POST INSTEAD OF DELETE
                const result = await apiPost(
                    '/api/ai-docs/delete',
                    { id: id },
                    {
                        headers: {
                            "X-Audit-User": loggedInUserName,
                            "X-Audit-FullName": loggedInFullName
                        }
                    }
                );

                if (result.success) {

                    await loadDocuments();

                    showAlert(
                        'success',
                        'Document Deleted',
                        'Document deleted successfully.'
                    );
                }
                else {

                    showAlert(
                        'error',
                        'Delete Failed',
                        result.error || 'Unable to delete document.'
                    );
                }
            }
            catch (err) {

                console.error(err);

                showAlert(
                    'error',
                    'Delete Failed',
                    err.message || 'Unable to delete the document.'
                );
            }
            finally {

                hideLoader();
            }
        }

        const fileInput = document.getElementById('docFile');
        const fileText = document.querySelector('.file-text');
        const fileWrap = document.querySelector('.file-upload');

        fileInput.addEventListener('change', () => {
            if (fileInput.files.length > 0) {
                fileText.textContent = fileInput.files[0].name;
                fileWrap.classList.add('selected');
            } else {
                fileText.textContent = 'Choose Document';
                fileWrap.classList.remove('selected');
            }
        });

        function logoRipple(e) {
            const bg = e.currentTarget.querySelector('.logo-bg');
            const ripple = document.createElement('span');

            ripple.style.position = 'absolute';
            ripple.style.width = '20px';
            ripple.style.height = '20px';
            ripple.style.borderRadius = '50%';
            ripple.style.background = 'rgba(255,255,255,.6)';
            ripple.style.left = (e.offsetX) + 'px';
            ripple.style.top = (e.offsetY) + 'px';
            ripple.style.transform = 'scale(1)';
            ripple.style.opacity = '1';
            ripple.style.transition = 'all .6s ease';

            bg.appendChild(ripple);

            setTimeout(() => {
                ripple.style.transform = 'scale(15)';
                ripple.style.opacity = '0';
            }, 10);

            setTimeout(() => ripple.remove(), 600);
        }
    </script>

</body>

</html>